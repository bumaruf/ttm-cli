{
  "name": "@bumaruf/ttm-cli",
  "version": "0.1.4",
  "description": "Pick a terminal theme and see it live in your own window",
  "type": "module",
  "bin": {
    "ttm": "./src/cli.ts"
  },
  "files": [
    "src",
    "themes",
    "README.md",
    "LICENSE"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bumaruf/ttm-cli.git"
  },
  "homepage": "https://github.com/bumaruf/ttm-cli#readme",
  "bugs": "https://github.com/bumaruf/ttm-cli/issues",
  "keywords": [
    "terminal",
    "theme",
    "tui",
    "gnome-terminal",
    "colorscheme"
  ],
  "engines": {
    "bun": ">=1.3.14"
  },
  "scripts": {
    "test": "bun test",
    "generate-builtin": "bun run scripts/generate-builtin.ts",
    "build": "bun run generate-builtin && bun build --compile src/cli.ts --outfile dist/ttm",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5"
  }
}
