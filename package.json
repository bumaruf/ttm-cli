{
  "name": "@bumaruf/ttm-cli",
  "version": "0.3.1",
  "description": "Terminal theme manager — pick a theme by seeing it live in the window you're sitting in",
  "type": "module",
  "bin": {
    "ttm": "./src/cli.ts"
  },
  "files": [
    "src",
    "themes",
    "README.md",
    "LICENSE"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bumaruf/ttm-cli.git"
  },
  "homepage": "https://github.com/bumaruf/ttm-cli#readme",
  "bugs": "https://github.com/bumaruf/ttm-cli/issues",
  "keywords": [
    "terminal-theme-manager",
    "terminal",
    "theme",
    "theme-manager",
    "theme-switcher",
    "tui",
    "cli",
    "gnome-terminal",
    "colorscheme",
    "color-scheme",
    "ansi",
    "dconf"
  ],
  "engines": {
    "bun": ">=1.3.14"
  },
  "scripts": {
    "prepare": "lefthook install",
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "generate-builtin": "bun run scripts/generate-builtin.ts",
    "build": "bun run generate-builtin && bun build --compile src/cli.ts --outfile dist/ttm",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.3",
    "@types/bun": "latest",
    "lefthook": "^2.1.10",
    "typescript": "^7"
  }
}
